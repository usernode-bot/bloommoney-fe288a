{
  "name": "BloomMoney",
  "secrets": [
    {
      "key": "BLOOM_ADMIN_USERNAME",
      "description": "Usernode username that receives the admin role on first sign-in",
      "required": false,
      "private": false,
      "default": ""
    },
    {
      "key": "X_OAUTH_CLIENT_ID",
      "description": "X (Twitter) OAuth2 client id for Social-tier verification and Twitter account linking",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "X_OAUTH_CLIENT_SECRET",
      "description": "X (Twitter) OAuth2 client secret for Social-tier verification and Twitter account linking",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "INSTAGRAM_OAUTH_CLIENT_ID",
      "description": "Instagram OAuth client id for Social-tier verification",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "INSTAGRAM_OAUTH_CLIENT_SECRET",
      "description": "Instagram OAuth client secret for Social-tier verification",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "TIKTOK_OAUTH_CLIENT_ID",
      "description": "TikTok OAuth client id for Social-tier verification",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "TIKTOK_OAUTH_CLIENT_SECRET",
      "description": "TikTok OAuth client secret for Social-tier verification",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "COINBASE_OAUTH_CLIENT_ID",
      "description": "Coinbase OAuth client id for Social-tier verification",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "COINBASE_OAUTH_CLIENT_SECRET",
      "description": "Coinbase OAuth client secret for Social-tier verification",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "GOOGLE_OAUTH_CLIENT_ID",
      "description": "Google OAuth client id for account linking",
      "required": false,
      "private": false,
      "default": ""
    },
    {
      "key": "GOOGLE_OAUTH_CLIENT_SECRET",
      "description": "Google OAuth client secret for account linking",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "DISCORD_OAUTH_CLIENT_ID",
      "description": "Discord OAuth client id for account linking",
      "required": false,
      "private": false,
      "default": ""
    },
    {
      "key": "DISCORD_OAUTH_CLIENT_SECRET",
      "description": "Discord OAuth client secret for account linking",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "GITHUB_OAUTH_CLIENT_ID",
      "description": "GitHub OAuth client id for account linking",
      "required": false,
      "private": false,
      "default": ""
    },
    {
      "key": "GITHUB_OAUTH_CLIENT_SECRET",
      "description": "GitHub OAuth client secret for account linking",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "BLOOM_OAUTH_REDIRECT_URI",
      "description": "Registered OAuth redirect URI providers send users back to (prod only)",
      "required": false,
      "private": false,
      "default": ""
    },
    {
      "key": "ZKPASSPORT_VERIFIER_URL",
      "description": "zkPassport proof verifier endpoint for Premium-tier verification",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "ZKPASSPORT_API_KEY",
      "description": "zkPassport verifier API key for Premium-tier verification",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "COINGECKO_API_KEY",
      "description": "CoinGecko API key for live crypto prices (optional; free demo tier works without it)",
      "required": false,
      "private": true,
      "staging_default": ""
    }
  ],
  "tests": [
    { "name": "Feed renders", "path": "/?demo=1", "expectSelector": "#app-feed" },
    { "name": "Opinion markets section in DOM", "path": "/?demo=1", "expectSelector": "#section-markets" },
    { "name": "Futures terminal in DOM", "path": "/?demo=1", "expectSelector": "#section-futures" },
    { "name": "Verify screen in DOM", "path": "/?demo=1", "expectSelector": "#section-verify" },
    { "name": "Explore screen in DOM", "path": "/?demo=1", "expectSelector": "#section-explore" },
    { "name": "Admin panel in DOM", "path": "/?demo=1", "expectSelector": "#section-admin" },
    { "name": "Admin console renders", "path": "/admin?demo=1", "expectSelector": "#admin-stats" },
    { "name": "Admin financials page renders", "path": "/admin/financials?demo=1", "expectSelector": "#admin-balances" },
    { "name": "Admin NFTs page renders", "path": "/admin/nfts?demo=1", "expectSelector": "#admin-nfts" },
    { "name": "Profile section in DOM", "path": "/?demo=1", "expectSelector": "#section-profile" },
    { "name": "Linked accounts section in DOM", "path": "/?demo=1", "expectSelector": "#linked-accounts-section" },
    { "name": "ZK verified badge in DOM", "path": "/?demo=1", "expectSelector": ".tag-zk-verified" },
    { "name": "Trade tab section in DOM", "path": "/?demo=1", "expectSelector": "#section-swap" },
    { "name": "Opinion market history API returns JSON", "path": "/api/markets/9001/history", "expectSelector": "body" },
    { "name": "Daily opinion market history API returns JSON", "path": "/api/markets/9010/history", "expectSelector": "body" },
    { "name": "Futures history API returns JSON", "path": "/api/futures/markets/1/history", "expectSelector": "body" },
    { "name": "Activity API returns JSON", "path": "/api/activity", "expectSelector": "body" },
    { "name": "Public portfolio API returns JSON", "path": "/explorer-api/portfolio/staging-alice", "expectSelector": "body" },
    { "name": "ICO offerings render in Earn tab", "path": "/?demo=1", "expectSelector": "#section-earn" },
    { "name": "Swap token card renders", "path": "/?demo=1", "expectSelector": ".swap-token-card" },
    { "name": "Token detail renders", "path": "/?demo=1", "expectSelector": ".token-market-row" },
    { "name": "Points available badge in DOM", "path": "/?demo=1", "expectSelector": "#points-available" }
  ]
}
