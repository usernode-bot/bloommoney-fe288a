{
  "name": "BloomMoney",
  "secrets": [
    {
      "key": "BLOOM_ADMIN_USERNAME",
      "description": "Username that receives admin role on first registration",
      "required": false,
      "private": false,
      "default": ""
    }
  ],
  "tests": [
    { "name": "Feed renders", "path": "/?demo=1", "expectSelector": "#app-feed" },
    { "name": "Opinion markets list renders", "path": "/?demo=1", "expectSelector": "#section-markets" },
    { "name": "Futures markets list renders", "path": "/?demo=1", "expectSelector": "#section-futures" },
    { "name": "Admin stats renders", "path": "/api/admin/stats", "expectSelector": null }
  ]
}
